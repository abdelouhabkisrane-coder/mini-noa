<?xml version="1.0"?>
<robot name="mini_nao">

  <!-- ========== WORLD ========== -->
  <link name="world"/>

  <!-- ========== BASE / TORSO ========== -->
  <link name="torso">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.12 0.08 0.18"/>
      </geometry>
      <material name="white">
        <color rgba="0.95 0.95 0.95 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.12 0.08 0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="world_to_torso" type="fixed">
    <parent link="world"/>
    <child link="torso"/>
    <origin xyz="0 0 0.5"/>
  </joint>

  <!-- ========== HEAD ========== -->
  <link name="head">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
      <material name="white">
        <color rgba="0.95 0.95 0.95 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="neck_joint" type="revolute">
    <parent link="torso"/>
    <child link="head"/>
    <origin xyz="0 0 0.13"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="1.0" effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== LEFT UPPER ARM ========== -->
  <link name="left_upper_arm">
    <visual>
      <origin xyz="0 0 -0.07"/>
      <geometry>
        <cylinder radius="0.025" length="0.14"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.07"/>
      <geometry>
        <cylinder radius="0.025" length="0.14"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_upper_arm"/>
    <origin xyz="0.08 0 0.07"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== RIGHT UPPER ARM ========== -->
  <link name="right_upper_arm">
    <visual>
      <origin xyz="0 0 -0.07"/>
      <geometry>
        <cylinder radius="0.025" length="0.14"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.07"/>
      <geometry>
        <cylinder radius="0.025" length="0.14"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_upper_arm"/>
    <origin xyz="-0.08 0 0.07"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== LEFT LOWER ARM ========== -->
  <link name="left_lower_arm">
    <visual>
      <origin xyz="0 0 -0.06"/>
      <geometry>
        <cylinder radius="0.02" length="0.12"/>
      </geometry>
      <material name="white">
        <color rgba="0.95 0.95 0.95 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06"/>
      <geometry>
        <cylinder radius="0.02" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_elbow_joint" type="revolute">
    <parent link="left_upper_arm"/>
    <child link="left_lower_arm"/>
    <origin xyz="0 0 -0.14"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== RIGHT LOWER ARM ========== -->
  <link name="right_lower_arm">
    <visual>
      <origin xyz="0 0 -0.06"/>
      <geometry>
        <cylinder radius="0.02" length="0.12"/>
      </geometry>
      <material name="white">
        <color rgba="0.95 0.95 0.95 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06"/>
      <geometry>
        <cylinder radius="0.02" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_elbow_joint" type="revolute">
    <parent link="right_upper_arm"/>
    <child link="right_lower_arm"/>
    <origin xyz="0 0 -0.14"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.57" effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== LEFT THIGH ========== -->
  <link name="left_thigh">
    <visual>
      <origin xyz="0 0 -0.09"/>
      <geometry>
        <cylinder radius="0.03" length="0.18"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.09"/>
      <geometry>
        <cylinder radius="0.03" length="0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_hip_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_thigh"/>
    <origin xyz="0.04 0 -0.09"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== RIGHT THIGH ========== -->
  <link name="right_thigh">
    <visual>
      <origin xyz="0 0 -0.09"/>
      <geometry>
        <cylinder radius="0.03" length="0.18"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.09"/>
      <geometry>
        <cylinder radius="0.03" length="0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_hip_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_thigh"/>
    <origin xyz="-0.04 0 -0.09"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== LEFT SHIN ========== -->
  <link name="left_shin">
    <visual>
      <origin xyz="0 0 -0.09"/>
      <geometry>
        <cylinder radius="0.025" length="0.18"/>
      </geometry>
      <material name="white">
        <color rgba="0.95 0.95 0.95 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.09"/>
      <geometry>
        <cylinder radius="0.025" length="0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_knee_joint" type="revolute">
    <parent link="left_thigh"/>
    <child link="left_shin"/>
    <origin xyz="0 0 -0.18"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== RIGHT SHIN ========== -->
  <link name="right_shin">
    <visual>
      <origin xyz="0 0 -0.09"/>
      <geometry>
        <cylinder radius="0.025" length="0.18"/>
      </geometry>
      <material name="white">
        <color rgba="0.95 0.95 0.95 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.09"/>
      <geometry>
        <cylinder radius="0.025" length="0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_knee_joint" type="revolute">
    <parent link="right_thigh"/>
    <child link="right_shin"/>
    <origin xyz="0 0 -0.18"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== LEFT FOOT ========== -->
  <link name="left_foot">
    <visual>
      <origin xyz="0.02 0 -0.02"/>
      <geometry>
        <box size="0.1 0.06 0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.02 0 -0.02"/>
      <geometry>
        <box size="0.1 0.06 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_ankle_joint" type="revolute">
    <parent link="left_shin"/>
    <child link="left_foot"/>
    <origin xyz="0 0 -0.18"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== RIGHT FOOT ========== -->
  <link name="right_foot">
    <visual>
      <origin xyz="0.02 0 -0.02"/>
      <geometry>
        <box size="0.1 0.06 0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.02 0 -0.02"/>
      <geometry>
        <box size="0.1 0.06 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_ankle_joint" type="revolute">
    <parent link="right_shin"/>
    <child link="right_foot"/>
    <origin xyz="0 0 -0.18"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="5" velocity="1.0"/>
  </joint>

</robot>
